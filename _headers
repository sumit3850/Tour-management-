# Cloudflare Pages headers.
# App shell + the tenant registry are served always-fresh so a code, branding or
# tenant change reaches every client on their next online load. Static assets are
# cached. (The service worker still provides offline access on top of this.)

/*.html
  Cache-Control: no-cache, must-revalidate

/config.js
  Cache-Control: no-cache, must-revalidate

/sw.js
  Cache-Control: no-cache, must-revalidate

/*.json
  Cache-Control: no-cache, must-revalidate

/assets/*
  Cache-Control: public, max-age=604800

/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: SAMEORIGIN
